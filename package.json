{
  "name": "polar-to-strava-fit",
  "description": "Convert your Polar bulk export to Strava-ready FIT files in your browser. Privacy-first, static-hosted.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "convert": "tsx src/cli/convert.ts",
    "inspect": "tsx src/cli/inspect.ts",
    "validate": "tsx src/cli/validate.ts"
  },
  "dependencies": {
    "@garmin/fitsdk": "^21.205.0",
    "adm-zip": "^0.5.16",
    "bits-ui": "^1.5.0",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "json5": "^2.2.3",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.1.21",
    "@tsconfig/svelte": "^5.0.8",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^24.12.3",
    "@vitest/browser": "^4.1.6",
    "playwright": "^1.50.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.1.21",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
